# MMUCC v5 — Production Environment Variables
# Copy to /opt/mmucc/app/.env on the EC2 instance and fill in real values.
# chmod 600 .env — this file must never be committed to git.

# ── AWS / ECR ────────────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
IMAGE_TAG=latest

# ── Database (MySQL container on EC2) ────────────────────────────────────────
# DB_HOST is always 127.0.0.1 — MySQL runs on the same EC2 instance.
DB_NAME=mmucc_prod
DB_USER=mmucc_app
DB_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_BASE64_ENCODED_SECRET_AT_LEAST_512_BITS
JWT_ISSUER=mmucc-app.duckdns.org
